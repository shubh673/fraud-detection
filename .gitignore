# =============================================================================
# .gitignore — Card & Payment Fraud Detection POC
#
# Goal: commit only what is needed to run the pipeline end-to-end
# (source code + input datasets + configs). Everything below is either a
# dependency you reinstall, or an artefact the pipeline regenerates.
#
# KEPT in the repo (do NOT ignore):
#   - src/ , scripts/ , frontend/src/ , frontend/public/{favicon,icons}.svg
#   - fraud_detection_enriched_dataset_pack/   (input datasets)
#   - config/merchant_blacklist.csv            (manual blacklist input)
#   - package.json / package-lock.json / *.md / vite/ts configs
# =============================================================================

# ---- Python virtual environment (recreate: pip install pandas scikit-learn joblib) ----
venv/
.venv/
env/

# ---- Python caches / bytecode ----
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ---- Pipeline OUTPUTS (regenerated by train_step1_model.py + client_requirement_pipeline.py) ----
# Includes the ~330 MB model bundle, which also exceeds GitHub's 100 MB file limit.
outputs/

# ---- Dashboard data (regenerated by scripts/prepare_dashboard_data.py) ----
frontend/public/data/

# ---- Input datasets: keep ONLY the files the pipeline actually reads ----
# The full pack is ~300 MB and includes files that:
#   (a) the implemented pipeline never opens (Steps 2/4/5 + reference data), and
#   (b) exceed GitHub's 100 MB per-file limit (historical_ehi_transactions = 143 MB,
#       synthetic_device_ip_events = 65 MB) — which would make `git push` fail.
# So we ignore the pack by default and re-include the 5 required CSVs + its README.
fraud_detection_enriched_dataset_pack/*
!fraud_detection_enriched_dataset_pack/ehi_authorisation_transactions_enriched.csv
!fraud_detection_enriched_dataset_pack/historical_cardholder_baselines_enriched.csv
!fraud_detection_enriched_dataset_pack/cardholder_profiles.csv
!fraud_detection_enriched_dataset_pack/merchant_profiles.csv
!fraud_detection_enriched_dataset_pack/synthetic_merchant_risk_events.csv
!fraud_detection_enriched_dataset_pack/README_ENRICHED.md

# ---- Node / frontend build artefacts (recreate: npm install / npm run build) ----
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.local
.eslintcache

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# ---- Local tooling / scratch ----
.claude-dev-helper/
scratchpad/
*.tmp

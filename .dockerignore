# Keep the Docker build context small & fast.
# (The pipeline stage regenerates outputs, model and dashboard data.)

.git/
venv/
.venv/
**/__pycache__/
*.pyc

# regenerated by the pipeline / build
outputs/
frontend/node_modules/
frontend/dist/
frontend/public/data/
node_modules/

# large datasets the implemented pipeline does NOT read
fraud_detection_enriched_dataset_pack/historical_ehi_transactions_enriched.csv
fraud_detection_enriched_dataset_pack/synthetic_device_ip_events.csv

# docs / local cruft not needed inside the image
*.md
.claude-dev-helper/
.DS_Store
Thumbs.db
